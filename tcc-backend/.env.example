DB_URL=jdbc:postgresql://localhost:5432/tcc
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL_MODE=disable

# Render/Supabase production example:
# DB_URL=jdbc:postgresql://aws-0-sa-east-1.pooler.supabase.com:6543/postgres?sslmode=require
# DB_SSL_MODE=require

# Generate a strong key (base64) and set here.
# Example command (PowerShell):
# [Convert]::ToBase64String((1..64 | ForEach-Object { Get-Random -Maximum 256 }))
JWT_SECRET=replace_with_base64_secret_min_32_bytes
JWT_EXPIRATION_MS=2592000000

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=replace_with_supabase_anon_key
# Optional for backend-only storage checks; prefer this on Render if available.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=documents

# Optional bootstrap; uncomment only after setting a strong private password.
# ADMIN_BOOTSTRAP_NAME=Administrador CollabResearch
# ADMIN_BOOTSTRAP_EMAIL=admin@collabresearch.local
# ADMIN_BOOTSTRAP_PASSWORD=replace_with_strong_admin_password

# Local defaults already include localhost and Vite ports used by local clients.
# In Render, restrict CORS to public browser applications; the desktop dev server uses a proxy.
# https://front-end-tcc-ten.vercel.app,https://*.vercel.app
CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:*,http://127.0.0.1:*,https://front-end-tcc-ten.vercel.app,https://*.vercel.app
